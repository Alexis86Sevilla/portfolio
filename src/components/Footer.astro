---
import SocialLinks from "./SocialLinks.astro";

const getCurrentYear = () => new Date().getFullYear();
---

<footer
  class="bg-gradient-to-br from-cyan-600 via-blue-700 to-gray-900 border-t border-white/10 py-20 px-6"
>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-5xl font-bold tracking-tighter mb-6">
      ¿Listo para trabajar juntos?
    </h2>
    <p class="text-gray-300 text-lg mb-10">
      Estoy disponible para nuevos proyectos y colaboraciones.
    </p>

    <a
      href="mailto:alexis@example.com"
      class="inline-block bg-white text-blue-900 px-8 py-4 rounded-full font-bold hover:scale-105 hover:shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-300 mb-16"
      >Envíame un mensaje</a
    >

    <div
      class="flex flex-col items-center gap-8 border-t border-white/20 pt-10"
    >
      <SocialLinks />
      <p class="text-cyan-200 text-sm">
        {getCurrentYear()} • Alexis García Mancha
      </p>
    </div>
  </div>
</footer>
