<div id="mouse-glow" class="pointer-events-none fixed inset-0 z-0 opacity-0 transition-opacity duration-300"></div>

<script>
  const glow = document.getElementById('mouse-glow');
  document.addEventListener('mousemove', (e) => {
    if (!glow) return;
    glow.style.opacity = '1';
    glow.style.background = `radial-gradient(600px at ${e.clientX}px ${e.clientY}px, rgba(29, 78, 216, 0.15), transparent 80%)`;
  });
</script>
