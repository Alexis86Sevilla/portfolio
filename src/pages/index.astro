---
import { getCollection } from "astro:content";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SEO from "../components/SEO.astro";
import Skills from "../components/Skills.astro";
import Layout from "../layouts/Layout.astro";

const allProjects = await getCollection("projects");
const recentProjects = allProjects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout>
  <SEO
    slot="head"
    title="Alexis Dev | Portfolio"
    description="Ingeniería de software con visión estratégica."
  />

  <Hero />

  <section class="py-16 md:py-20 container mx-auto px-4 md:px-6 max-w-6xl" id="proyectos">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tighter mb-12 md:mb-16 text-center">
      Proyectos
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {recentProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <Skills />
</Layout>
